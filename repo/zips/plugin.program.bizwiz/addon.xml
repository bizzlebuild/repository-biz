<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.program.bizwiz" name="Bizzle Wizard" version="2.0.10" provider-name="bizzlebuild">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.service" library="startup.py" start="startup"/>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Bizzle Wizard for Kodi Omega</summary>
        <description lang="en_GB">Bizzle Wizard offers build installs and basic maintenance tools for your own Kodi builds.</description>
        <platform>all</platform>
        <license>GPL-3.0-only</license>
        <source>https://github.com/bizzlebuild/plugin.program.bizwiz</source>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
        <news>2.0.9 - Clean Kodi Omega compatible wizard files.</news>
    </extension>
</addon>
