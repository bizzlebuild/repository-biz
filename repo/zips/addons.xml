<?xml version='1.0' encoding='utf-8'?>
<addons><addon id="plugin.program.bizwiz" name="Bizzle Wizard" version="2.0.10" provider-name="bizzlebuild">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.service" library="startup.py" start="startup" />
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Bizzle Wizard for Kodi Omega</summary>
        <description lang="en_GB">Bizzle Wizard offers build installs and basic maintenance tools for your own Kodi builds.</description>
        <platform>all</platform>
        <license>GPL-3.0-only</license>
        <source>https://github.com/bizzlebuild/plugin.program.bizwiz</source>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
        <news>2.0.9 - Clean Kodi Omega compatible wizard files.</news>
    </extension>
</addon><addon id="repository,biz" name="Bizzle Repo" version="1.0" provider-name="bizzlebuild">
    <extension point="xbmc.addon.repository" name="Bizzles Repo">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/bizzlebuild/repository.biz/master/repo/zips/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/bizzlebuild/repository.biz/master/repo/zips/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/bizzlebuild/repository.biz/master/repo/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Bizzle Repo</summary>
        <description>Repository for bizzles builds</description>
        <disclaimer />
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon></addons>